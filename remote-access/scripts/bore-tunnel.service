[Unit]
Description=Bore Tunnel to bore.pub for NoMachine
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/.local/bin/bore-tunnel.sh
Restart=always
RestartSec=5
KillMode=mixed

[Install]
# Not enabled by default — started on-demand via ntfy command ("bore")
# To re-enable persistent: systemctl --user enable bore-tunnel.service
# WantedBy=default.target
