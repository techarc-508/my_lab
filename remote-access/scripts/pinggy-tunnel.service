[Unit]
Description=Pinggy Tunnel to a.pinggy.io for NoMachine
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/.local/bin/pinggy-tunnel.sh
Restart=always
RestartSec=5
KillMode=mixed

[Install]
WantedBy=default.target
