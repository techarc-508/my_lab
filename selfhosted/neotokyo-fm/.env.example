# NEOTOKYO FM — Environment Variables
# Copy to .env and fill in your values.

# ═══ Server (Flask + Gunicorn) ══════════════════════════════════════

# Admin credentials (REQUIRED for production)
# If not set, a random 16-char password is generated on each startup (logged to console)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_to_a_strong_password

# Flask secret key for session signing
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Server bind address and port
HOST=0.0.0.0
PORT=5050

# CORS origin — must match your frontend URL exactly
# Examples: http://localhost:3000, http://localhost:80, https://radio.example.com
# Leave empty to echo the request Origin (less restrictive)
CORS_ORIGIN=http://localhost:3000

# ═══ Gunicorn (production) ═════════════════════════════════════════
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
# GUNICORN_ACCESS_LOG=-
# GUNICORN_ERROR_LOG=-
# GUNICORN_LOGLEVEL=info

# ═══ Rate Limits ═══════════════════════════════════════════════════
LOGIN_RATE_LIMIT=5        # max failed attempts per window
LOGIN_RATE_WINDOW=300     # window in seconds (5 min)
MAX_CONCURRENCY=5         # concurrent downloads per batch
MAX_BATCHES=10            # simultaneous batches
MAX_UPLOAD_MB=32          # upload file size limit
MAX_DOWNLOAD_AGE_DAYS=7   # auto-evict completed downloads

# ═══ LRCLIB Lyrics ════════════════════════════════════════════════
LRCLIB_TIMEOUT=4          # HTTP timeout in seconds
LRCLIB_SKIP=0             # set to 1 to disable lyrics fetching

# ═══ Frontend (Vite) ══════════════════════════════════════════════
# API base URL for the React dev server
# In Codespaces: https://<hash>-5050.app.github.dev
# VITE_API_BASE=http://127.0.0.1:5050
